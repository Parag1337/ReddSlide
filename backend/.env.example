# RedSlide Backend Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Reddit API credentials (required)
# Register at https://www.reddit.com/prefs/apps to get these.
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# User-Agent sent with every Reddit API request.
# Format: <app_name>/<version> by u/<reddit_username>
REDDIT_USER_AGENT=RedSlide/1.0 by u/your_username

# Path to SQLite database file (relative to backend/ directory)
DATABASE_PATH=./data/redslide.db
